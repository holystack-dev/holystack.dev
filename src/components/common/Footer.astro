---
const year = new Date().getFullYear();
---

<footer class="bg-white dark:bg-[#0f0f14] border-t border-gray-100 dark:border-white/5 py-12">
  <div class="max-w-[1200px] mx-auto px-6 grid md:grid-cols-3 gap-8">
    <div class="col-span-1 md:col-span-2">
      <a href="/" class="flex items-center gap-2 mb-4">
        <div class="text-purple-700 dark:text-purple-400 w-8 h-8">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" class="w-full h-full">
              <path d="M32 52L8 40V34L32 46L56 34V40L32 52Z" fill="currentColor" opacity="0.3"/>
              <path d="M32 44L8 32V26L32 38L56 26V32L32 44Z" fill="currentColor" opacity="0.5"/>
              <path d="M32 36L8 24V18L32 30L56 18V24L32 36Z" fill="currentColor" opacity="0.7"/>
              <rect x="29" y="4" width="6" height="24" rx="1" fill="currentColor"/>
              <rect x="22" y="10" width="20" height="6" rx="1" fill="currentColor"/>
            </svg>
        </div>
        <span class="font-serif font-bold text-lg tracking-wide text-gray-900 dark:text-white">HOLYSTACK</span>
      </a>
      <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed max-w-xs">
        Free, open source Catholic apps.
      </p>
    </div>

    <div>
      <h3 class="font-serif font-bold text-gray-900 dark:text-white mb-4">Connect</h3>
      <ul class="space-y-2">
        <li>
          <a href="https://github.com/holystack-dev" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 dark:text-gray-400 hover:text-purple-700 dark:hover:text-purple-400 transition-colors inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </li>
        <li><a href="/privacy" class="text-sm text-gray-500 dark:text-gray-400 hover:text-purple-700 dark:hover:text-purple-400 transition-colors">Privacy Policy</a></li>
        <li><a href="/contact" class="text-sm text-gray-500 dark:text-gray-400 hover:text-purple-700 dark:hover:text-purple-400 transition-colors">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-6 mt-12 pt-8 border-t border-gray-100 dark:border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-xs text-gray-400 dark:text-gray-500">
      &copy; {year} HolyStack Ltd. All rights reserved.
    </p>
    <p class="text-xs font-serif italic text-purple-700 dark:text-purple-400">
      Ad Maiorem Dei Gloriam
    </p>
  </div>
</footer>
