---
interface Props {
  class?: string;
  href?: string;
}

const { class: className, href } = Astro.props;

const baseStyles = "block bg-white dark:bg-[#1a1a24] rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100 dark:border-white/5 overflow-hidden group";
---

{
  href ? (
    <a href={href} class:list={[baseStyles, "hover:-translate-y-1", className]}>
      <slot />
    </a>
  ) : (
    <div class:list={[baseStyles, className]}>
      <slot />
    </div>
  )
}
