---
import Container from '../common/Section.astro';
import Button from '../common/Button.astro';
import Scripture from '../common/Scripture.astro';
---

<section class="relative bg-white dark:bg-[#0f0f14] py-24 md:py-32 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-purple-50 dark:bg-purple-900/10 rounded-full blur-3xl -z-10 opacity-60"></div>

  <div class="max-w-[1200px] mx-auto px-6 text-center">
    <!-- Logo -->
    <div class="inline-flex items-center justify-center w-24 h-24 mb-8 text-purple-700 dark:text-purple-400">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" class="w-full h-full">
          <!-- Stacked layers representing "stack" -->
          <path d="M32 52L8 40V34L32 46L56 34V40L32 52Z" fill="currentColor" opacity="0.3"/>
          <path d="M32 44L8 32V26L32 38L56 26V32L32 44Z" fill="currentColor" opacity="0.5"/>
          <path d="M32 36L8 24V18L32 30L56 18V24L32 36Z" fill="currentColor" opacity="0.7"/>
          <!-- Cross on top representing "holy" -->
          <rect x="29" y="4" width="6" height="24" rx="1" fill="currentColor"/>
          <rect x="22" y="10" width="20" height="6" rx="1" fill="currentColor"/>
        </svg>
    </div>

    <h1 class="font-serif font-bold text-5xl md:text-7xl mb-6 tracking-tight text-gray-900 dark:text-white">
      HOLYSTACK
    </h1>
    
    <p class="text-xl md:text-2xl text-purple-800 dark:text-purple-300 font-medium mb-8">
      Code for the Church
    </p>

    <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8 leading-relaxed">
      Free Catholic apps and software to deepen your faith, prayer, and sacramental life.
    </p>

    <!-- Open Source Badge -->
    <div class="flex items-center justify-center gap-2 mb-12">
      <a
        href="https://github.com/holystack-dev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-white/10 border border-gray-200 dark:border-white/10 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-white/20 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        All Apps Open Source — Contribute on GitHub
      </a>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <Button href="#apps" variant="primary">Explore Our Apps</Button>
    </div>

    <Scripture 
      quote="For we are God's handiwork, created in Christ Jesus to do good works."
      reference="Ephesians 2:10"
      centered={true}
      class="opacity-80"
    />
  </div>
</section>
