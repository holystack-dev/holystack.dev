---
import Section from '../common/Section.astro';
import Card from '../common/Card.astro';
---

<Section id="apps" background="white">
  <div class="text-center mb-16">
    <h2 class="font-serif text-4xl font-bold mb-4 text-gray-900 dark:text-white">Apps for the Faithful</h2>
    <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
      Tools to support your daily walk with Christ.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
    <!-- Metanoia Card -->
    <Card href="/metanoia" class="group relative overflow-hidden h-full flex flex-col">
      <div class="h-48 bg-gradient-to-br from-purple-900 to-gray-900 flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('/images/noise.png')] opacity-10 mix-blend-overlay"></div>
        <!-- Open Source Badge -->
        <div class="absolute top-3 right-3 inline-flex items-center gap-1 px-2 py-1 bg-white/20 backdrop-blur-sm rounded-full text-xs font-medium text-white">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Open Source
        </div>
        <div class="text-white/90 w-20 h-20">
             <img src="/images/metanoia/logo.png" alt="Metanoia Logo" class="w-full h-full object-contain drop-shadow-xl" />
        </div>
      </div>

      <div class="p-8 flex flex-col flex-grow">
        <h3 class="font-serif text-2xl font-bold text-gray-900 dark:text-white mb-2">Metanoia</h3>
        <p class="text-purple-700 dark:text-purple-400 font-medium mb-4 text-sm uppercase tracking-wide">Catholic Confession</p>
        
        <p class="text-gray-600 dark:text-gray-400 mb-8 flex-grow">
          Turn Back to Grace. Your faithful companion for the Sacrament of Reconciliation. Examination of conscience, step-by-step guide, and prayers.
        </p>
        
        <div class="flex gap-4 mt-auto">
          <span class="text-sm font-semibold text-purple-700 dark:text-purple-400 group-hover:underline">Learn More →</span>
        </div>
      </div>
    </Card>

    <!-- Audio Bible Card -->
    <Card href="/shema" class="group relative overflow-hidden h-full flex flex-col">
      <div class="h-48 bg-gradient-to-br from-gray-900 to-purple-900 flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('/images/noise.png')] opacity-10 mix-blend-overlay"></div>
        <!-- Open Source Badge -->
        <div class="absolute top-3 right-3 inline-flex items-center gap-1 px-2 py-1 bg-white/20 backdrop-blur-sm rounded-full text-xs font-medium text-white">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Open Source
        </div>
        <img src="/images/shema/screens/home.png" alt="Shema screen" class="h-40 w-40 object-contain drop-shadow-xl group-hover:scale-105 transition-transform duration-300" />
      </div>

      <div class="p-8 flex flex-col flex-grow">
        <h3 class="font-serif text-2xl font-bold text-gray-900 dark:text-white mb-2">Shema</h3>
        <p class="text-purple-700 dark:text-purple-400 font-medium mb-4 text-sm uppercase tracking-wide">Audio Bible · "Hear"</p>

        <p class="text-gray-600 dark:text-gray-400 mb-8 flex-grow">
          An offline audio Bible player named for the <em>Shema</em> ("Hear, O Israel"). Open-source firmware for a round touchscreen device, flashed right from your browser.
        </p>

        <div class="flex gap-4 mt-auto">
          <span class="text-sm font-semibold text-purple-700 dark:text-purple-400 group-hover:underline">Learn More →</span>
        </div>
      </div>
    </Card>

    <!-- Coming Soon Card -->
    <div class="flex flex-col justify-center items-center p-8 text-center rounded-2xl border-2 border-dashed border-gray-200 dark:border-white/10 h-full min-h-[400px]">
      <div class="text-gray-300 dark:text-gray-600 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v8"/>
          <path d="M8 12h8"/>
        </svg>
      </div>
      <h3 class="font-serif text-xl font-bold text-gray-500 dark:text-gray-500 mb-2">More Coming Soon</h3>
      <p class="text-gray-400 dark:text-gray-600 text-sm max-w-xs">
        We are building more tools for the Church. Stay tuned.
      </p>
    </div>
  </div>
</Section>
