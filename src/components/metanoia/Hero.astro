---
import Scripture from '../common/Scripture.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-purple-950 via-purple-900 to-gray-900"></div>

  <!-- Decorative Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <!-- Light rays effect -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-gradient-radial from-purple-500/20 via-transparent to-transparent rounded-full blur-3xl"></div>
    <div class="absolute top-20 left-1/4 w-[400px] h-[400px] bg-purple-600/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute top-40 right-1/4 w-[300px] h-[300px] bg-amber-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-[1200px] mx-auto px-6 py-20 text-center">
    <!-- App Icon -->
    <div class="inline-flex items-center justify-center w-24 h-24 md:w-32 md:h-32 mb-8 rounded-3xl bg-white/10 backdrop-blur-sm border border-white/20 shadow-2xl">
      <img src="/images/metanoia/logo.png" alt="Metanoia Catholic Confession App icon" class="w-16 h-16 md:w-20 md:h-20 object-contain brightness-0 invert drop-shadow-lg" loading="eager" width="80" height="80" />
    </div>

    <!-- Title -->
    <h1 class="font-serif font-bold text-5xl md:text-7xl lg:text-8xl text-white mb-6 tracking-tight">
      METANOIA
      <span class="block text-lg md:text-xl text-purple-200 font-medium uppercase tracking-widest font-sans mt-4">Catholic Confession App</span>
    </h1>

    <!-- Tagline -->
    <p class="text-3xl md:text-4xl lg:text-5xl font-serif text-amber-200/90 mb-8">
      Turn Back to Grace
    </p>

    <!-- Description -->
    <p class="text-lg md:text-xl text-purple-100/80 max-w-2xl mx-auto mb-8 leading-relaxed">
      Your faithful companion for preparing and receiving the Sacrament of Reconciliation.
      <br class="hidden md:block" />
      <span class="text-purple-200/60">Examine your conscience. Open your heart. Receive His mercy.</span>
    </p>

    <!-- Open Source Badge -->
    <div class="flex justify-center mb-12">
      <a
        href="https://github.com/holystack-dev/metanoia"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full text-sm font-medium text-purple-200 hover:bg-white/20 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Open Source — Contribute on GitHub
      </a>
    </div>

    <!-- Download Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a
        href="https://apps.apple.com/app/id6759740034"
        class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-100 transition-all hover:scale-105 shadow-lg"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div class="text-left">
          <div class="text-[10px] opacity-60 uppercase">Download on the</div>
          <div class="text-sm font-bold -mt-0.5">App Store</div>
        </div>
      </a>

      <a
        href="https://play.google.com/store/apps/details?id=dev.holystack.metanoia"
        class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-100 transition-all hover:scale-105 shadow-lg"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
        </svg>
        <div class="text-left">
          <div class="text-[10px] opacity-60 uppercase">Get it on</div>
          <div class="text-sm font-bold -mt-0.5">Google Play</div>
        </div>
      </a>
    </div>

    <!-- Scripture Quote -->
    <div class="max-w-2xl mx-auto">
      <blockquote class="font-serif italic text-lg md:text-xl text-purple-200/70 leading-relaxed">
        "Come now, let us settle the matter," says the Lord.<br />
        "Though your sins are like scarlet, they shall be as white as snow."
      </blockquote>
      <p class="mt-3 text-sm text-purple-300/50 uppercase tracking-widest">
        — Isaiah 1:18
      </p>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<style>
  .bg-gradient-radial {
    background: radial-gradient(circle, var(--tw-gradient-stops));
  }
</style>
