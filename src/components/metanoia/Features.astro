---
import Section from '../common/Section.astro';

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
    title: 'Examination of Conscience',
    description: '335 questions across the Ten Commandments, Precepts of the Church, Capital Sins, and more. Take your time — the Holy Spirit will guide you.',
    scripture: '"Create in me a pure heart, O God, and renew a steadfast spirit within me." — Psalm 51:10',
    color: 'purple'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    title: 'Step-by-Step Guide',
    description: 'Never feel lost. Follow along with prayers and prompts through the entire sacrament — from greeting to absolution to penance.',
    color: 'blue'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`,
    title: 'Complete Privacy',
    description: 'Your examination is between you and God. All data is encrypted on your device, with PIN and biometric protection.',
    scripture: '"You have searched me, Lord, and you know me." — Psalm 139:1',
    color: 'green'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>`,
    title: 'Personal Reflections',
    description: 'Add your own notes and reflections. Link them to specific commandments for a thorough, honest examination.',
    color: 'amber'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'Your Spiritual Journey',
    description: 'Optionally keep a private record of your confessions. Watch your growth in grace over time.',
    color: 'indigo'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>`,
    title: 'Gentle Reminders',
    description: 'Set reminders to maintain the beautiful practice of frequent confession — a wellspring of grace for the spiritual life.',
    color: 'rose'
  }
];

const colorClasses = {
  purple: { bg: 'bg-purple-100 dark:bg-purple-900/30', text: 'text-purple-600 dark:text-purple-400' },
  blue: { bg: 'bg-blue-100 dark:bg-blue-900/30', text: 'text-blue-600 dark:text-blue-400' },
  green: { bg: 'bg-emerald-100 dark:bg-emerald-900/30', text: 'text-emerald-600 dark:text-emerald-400' },
  amber: { bg: 'bg-amber-100 dark:bg-amber-900/30', text: 'text-amber-600 dark:text-amber-400' },
  indigo: { bg: 'bg-indigo-100 dark:bg-indigo-900/30', text: 'text-indigo-600 dark:text-indigo-400' },
  rose: { bg: 'bg-rose-100 dark:bg-rose-900/30', text: 'text-rose-600 dark:text-rose-400' }
};
---

<Section id="features" background="gray" class="py-20 md:py-32">
  <div class="text-center mb-16">
    <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-4">
      Prepare Your Heart<br />
      <span class="text-purple-700 dark:text-purple-400 text-2xl md:text-3xl lg:text-4xl">with the Metanoia Confession App</span>
    </h2>
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
      Everything you need to make a good confession — examination of conscience, prayers, and step-by-step guidance.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
    {features.map((feature) => {
      const colors = colorClasses[feature.color as keyof typeof colorClasses];
      return (
        <div class="group bg-white dark:bg-[#1a1a24] rounded-2xl p-6 md:p-8 border border-gray-100 dark:border-white/5 hover:border-purple-200 dark:hover:border-purple-800/50 transition-all hover:shadow-lg hover:-translate-y-1">
          <!-- Icon -->
          <div class={`w-12 h-12 ${colors.bg} ${colors.text} rounded-xl flex items-center justify-center mb-5`}>
            <Fragment set:html={feature.icon} />
          </div>

          <!-- Title -->
          <h3 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-3">
            {feature.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
            {feature.description}
          </p>

          <!-- Scripture (if available) -->
          {feature.scripture && (
            <p class="text-sm font-serif italic text-purple-600 dark:text-purple-400 border-t border-gray-100 dark:border-white/5 pt-4 mt-4">
              {feature.scripture}
            </p>
          )}
        </div>
      );
    })}
  </div>
</Section>
