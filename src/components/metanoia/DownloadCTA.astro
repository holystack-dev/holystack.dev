---

---

<section id="download" class="relative py-20 md:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-900 via-purple-800 to-gray-900"></div>

  <!-- Decorative Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-purple-600/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-amber-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6 text-center">
    <!-- Icon -->
    <div class="inline-flex items-center justify-center w-24 h-24 mb-8 rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20">
      <img src="/images/metanoia/logo.png" alt="Metanoia Catholic Confession App logo" class="w-16 h-16 object-contain brightness-0 invert" loading="lazy" width="64" height="64" />
    </div>

    <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
      Download Metanoia —<br />
      <span class="text-amber-200/90">Your Free Catholic Confession App</span>
    </h2>

    <p class="text-lg md:text-xl text-purple-100/80 max-w-2xl mx-auto mb-12">
      Download Metanoia free on iOS and Android.
    </p>

    <!-- Download Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
      <a
        href="https://apps.apple.com/app/id6759740034"
        class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-100 transition-all hover:scale-105 shadow-lg"
      >
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div class="text-left">
          <div class="text-xs opacity-60 uppercase">Download on the</div>
          <div class="text-lg font-bold -mt-0.5">App Store</div>
        </div>
      </a>

      <a
        href="https://play.google.com/store/apps/details?id=dev.holystack.metanoia"
        class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-100 transition-all hover:scale-105 shadow-lg"
      >
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
        </svg>
        <div class="text-left">
          <div class="text-xs opacity-60 uppercase">Get it on</div>
          <div class="text-lg font-bold -mt-0.5">Google Play</div>
        </div>
      </a>
    </div>

    <!-- Language Note -->
    <p class="text-purple-200/60 text-sm mb-12">
      Available in English, Malayalam, Brazilian Portuguese, French, and Spanish
    </p>

    <!-- Scripture -->
    <div class="max-w-2xl mx-auto">
      <blockquote class="font-serif italic text-lg md:text-xl text-purple-200/70 leading-relaxed">
        "The sacrifice acceptable to God is a broken spirit; a broken and contrite heart, O God, you will not despise."
      </blockquote>
      <p class="mt-4 text-sm text-purple-300/50 uppercase tracking-widest">
        — Psalm 51:17
      </p>
    </div>
  </div>
</section>
