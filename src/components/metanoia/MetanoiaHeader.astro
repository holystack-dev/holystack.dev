---
const links = [
  { href: '#features', label: 'Features' },
  { href: '#privacy', label: 'Privacy' },
  { href: '#faq', label: 'FAQ' },
  { href: '/', label: 'Holystack' },
];
---

<header class="fixed w-full top-0 z-50 bg-white/80 dark:bg-[#0f0f14]/80 backdrop-blur-md border-b border-gray-100 dark:border-white/5">
  <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/metanoia/" class="flex items-center gap-3 group">
      <div class="w-10 h-10">
        <img src="/images/metanoia/logo.png" alt="Metanoia" class="w-full h-full object-contain dark:brightness-0 dark:invert" />
      </div>
      <div class="flex flex-col">
        <span class="font-serif font-bold text-lg tracking-wide text-gray-900 dark:text-white leading-none">METANOIA</span>
        <span class="text-[10px] text-purple-600 dark:text-purple-400 uppercase tracking-widest">Catholic Confession</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-purple-700 dark:hover:text-purple-400 transition-colors"
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >
          {link.label}
          {link.external && (
            <svg class="inline-block w-3 h-3 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          )}
        </a>
      ))}
      <a
        href="#download"
        class="px-4 py-2 bg-purple-700 hover:bg-purple-800 text-white text-sm font-medium rounded-lg transition-colors"
      >
        Download
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="metanoia-menu-toggle" class="md:hidden text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="12" y2="12" />
        <line x1="4" x2="20" y1="6" y2="6" />
        <line x1="4" x2="20" y1="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="metanoia-mobile-menu" class="hidden md:hidden absolute top-16 left-0 w-full bg-white dark:bg-[#0f0f14] border-b border-gray-100 dark:border-white/5 p-4 flex flex-col gap-4 shadow-lg">
    {links.map(link => (
      <a
        href={link.href}
        class="text-base font-medium text-gray-600 dark:text-gray-400 hover:text-purple-700 dark:hover:text-purple-400 transition-colors"
        target={link.external ? '_blank' : undefined}
        rel={link.external ? 'noopener noreferrer' : undefined}
      >
        {link.label}
      </a>
    ))}
    <a
      href="#download"
      class="px-4 py-3 bg-purple-700 text-white text-center font-medium rounded-lg"
    >
      Download
    </a>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('metanoia-menu-toggle');
  const mobileMenu = document.getElementById('metanoia-mobile-menu');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });

  document.addEventListener('click', (e) => {
    if (!mobileMenu?.contains(e.target as Node) && !menuToggle?.contains(e.target as Node)) {
      mobileMenu?.classList.add('hidden');
    }
  });
</script>
