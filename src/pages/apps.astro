---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/common/Section.astro';
import Card from '../components/common/Card.astro';
---

<MainLayout 
  title="Our Apps - Holystack"
  description="Explore our collection of free Catholic apps."
>
  <Section class="bg-purple-900 text-white py-20">
    <div class="text-center">
      <h1 class="font-serif text-5xl font-bold mb-6">Our Apps</h1>
      <p class="text-purple-200 text-xl max-w-2xl mx-auto">
        Tools for the faithful, built with excellence and prayer.
      </p>
    </div>
  </Section>

  <Section>
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Metanoia Card (Detailed) -->
      <Card href="/metanoia" class="group relative overflow-hidden flex flex-col md:flex-row h-full">
        <div class="w-full md:w-2/5  bg-gradient-to-br from-purple-900 to-gray-900 flex items-center justify-center p-8 relative overflow-hidden">
          <div class="absolute inset-0 bg-[url('/images/noise.png')] opacity-10 mix-blend-overlay"></div>
          <div class="text-white/90 w-32 h-32">
             <img src="/images/metanoia/logo.png" alt="Metanoia Logo" class="w-full h-full object-contain drop-shadow-2xl" />
          </div>
        </div>
        
        <div class="p-8 w-full md:w-3/5 flex flex-col justify-center">
          <h2 class="font-serif text-3xl font-bold text-gray-900 dark:text-white mb-2">Metanoia</h2>
          <p class="text-purple-700 dark:text-purple-400 font-medium mb-4 uppercase tracking-wide">Catholic Confession</p>
          
          <p class="text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">
            A complete companion for the Sacrament of Reconciliation. Featuring a guided examination of conscience, step-by-step ritual guide, and prayers.
          </p>
          
          <div>
            <span class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-purple-800 hover:bg-purple-700 shadow-sm transition-colors">
              View App
            </span>
          </div>
        </div>
      </Card>
    </div>

    <div class="mt-24 text-center">
      <p class="text-gray-500 dark:text-gray-400 mb-4">More apps coming soon...</p>
      <div class="w-16 h-1 bg-purple-100 dark:bg-purple-900/30 mx-auto rounded-full"></div>
    </div>
  </Section>
</MainLayout>
