---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/common/Section.astro';
import Button from '../components/common/Button.astro';
---

<MainLayout 
  title="Contact Us - Holystack"
  description="Get in touch with Holystack."
>
  <Section class="py-20 min-h-[60vh] flex items-center">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="font-serif text-5xl font-bold mb-8 text-gray-900 dark:text-white">Get in Touch</h1>
      
      <p class="text-xl text-gray-600 dark:text-gray-400 mb-12 leading-relaxed">
        We'd love to hear from you. Whether you have feedback, a feature request, or just want to say hello.
      </p>

      <div class="bg-white dark:bg-[#1a1a24] p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-white/5">
        <p class="text-gray-900 dark:text-gray-200 font-medium mb-4">Email us at:</p>
        <a href="mailto:hello@holystack.dev" class="text-3xl md:text-4xl font-serif font-bold text-purple-700 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 transition-colors">
          hello@holystack.dev
        </a>
      </div>
      
      <div class="mt-12">
        <p class="text-sm text-gray-500 dark:text-gray-500">
            "Peace I leave with you; my peace I give you." — John 14:27
        </p>
      </div>
    </div>
  </Section>
</MainLayout>
